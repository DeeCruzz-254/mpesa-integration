# M-Pesa Integration Environment Variables

# Server Configuration
PORT=3000
NODE_ENV=development

# M-Pesa OAuth Credentials
# Get these from your Safaricom developer account
CONSUMER_KEY=xxxxx
CONSUMER_SECRET=xxxxxxx
# M-Pesa Business Configuration
BUSINESS_SHORT_CODE=xxxxx
PASS_KEY=xxxxx

# Callback Configuration
# This should be your public URL where M-Pesa will send callbacks
CALLBACK_URL=  https://unslumped-ladonna-unmildewed.ngrok-free.dev/api/mpesa/callback

# Optional: M-Pesa Certificate Path (for callback signature verification)
# Leave empty to skip verification during development
MPESA_CERT_PATH=./mpesa-cert.pem
